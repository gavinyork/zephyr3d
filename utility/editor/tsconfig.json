{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "downlevelIteration": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["es2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noImplicitAny": false,
    "preserveConstEnums": false,
    "listEmittedFiles": true,
    "noUnusedLocals": true,
    "strictNullChecks": false,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": false,
    "emitDecoratorMetadata": false,
    "sourceMap": true,
    "stripInternal": true,
    "typeRoots": ["./node_modules/@webgpu/types"],
    "baseUrl": ".",
    "paths": {
      "@zephyr3d/base": ["../../libs/base/src/index.ts"],
      "@zephyr3d/device": ["../../libs/device/src/index.ts"],
      "@zephyr3d/scene": ["../../libs/scene/src/index.ts"],
      "@zephyr3d/imgui": ["../../libs/imgui/src/index.ts"],
      "@zephyr3d/backend-webgl": ["../../libs/backend-webgl/src/index.ts"],
      "@zephyr3d/backend-webgpu": ["../../libs/backend-webgpu/src/index.ts"]
    }
  },
  "include": ["./src"],
  "exclude": ["node_modules", "**/*.spec.ts", "**/*.d.ts"]
}
