{
  "compilerOptions": {
    "moduleResolution": "bundler",
    "target": "ES2015",
    "module": "ES2015",
    "lib": ["ES6", "ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "noImplicitAny": false,
    "preserveConstEnums": false,
    "listEmittedFiles": true,
    "noUnusedLocals": true,
    "strictNullChecks": false,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": false,
    "sourceMap": true,
    "stripInternal": true,
    "typeRoots": ["./node_modules/@webgpu/types"]
  },
  "include": ["src", "types/raw.d.ts"],
  "exclude": ["node_modules", "**/*.spec.ts", "common/temp", "**/common/temp"]
}
